{
  "manifest_version": 3,
  "name": "nomusic",
  "version": "0.1.0",
  "description": "Strip music from videos on YouTube, Facebook, and the rest of the web using a local source-separation backend.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://127.0.0.1:8723/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "nomusic",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
