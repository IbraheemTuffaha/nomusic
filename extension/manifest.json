{
  "manifest_version": 3,
  "name": "nomusic",
  "version": "0.2.0",
  "description": "Removes the background music from the video you're watching and plays a vocals-only version of its audio in sync with the video.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://nomusic.example.com/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtube-nocookie.com/*",
        "*://*.facebook.com/*"
      ],
      "js": ["page-script.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtube-nocookie.com/*",
        "*://*.facebook.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "nomusic",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/button.png",
        "config.js",
        "main.js",
        "settings.js",
        "session.js",
        "button.js",
        "mute-controller.js",
        "audio-scheduler.js",
        "stretch.js",
        "third_party/soundtouch/*.js"
      ],
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtube-nocookie.com/*",
        "*://*.facebook.com/*"
      ]
    }
  ]
}
